// --- Utility Rules ---
WHITESPACE = _{ " " | "\t" | "\r\n" | "\n" }

// --- Top-Level Rules ---
script = { SOI ~ statement* ~ EOI }

// --- Statements ---
statement = { declaration | assignment | expression | include | import }

include = { "include" ~ string }
import = { "import" ~ string ~ "as" ~ identifier }

// --- Declarations ---
declaration = { workspace_decl | project_decl | stage_decl | task_decl }

workspace_decl = { "workspace" ~ identifier ~ "{" ~ workspace_body ~ "}" }
workspace_body = { statement* }

project_decl = { "project" ~ identifier ~ "{" ~ project_body ~ "}" }
project_body = { statement* }

stage_decl = { "stage" ~ identifier ~ "(" ~ arguments? ~ ")" ~ "{" ~ stage_body ~ "}" }
stage_body = { statement* }

task_decl = { "task" ~ identifier ~ "(" ~ arguments? ~ ")" ~ "{" ~ task_body ~ "}" }
task_body = { statement* }

// --- Assignments ---
assignment = { identifier ~ "=" ~ expression }

// --- Expressions ---
expression = { value | identifier }

// --- Values ---
value = { string | boolean | number | shell_string | array }

array = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
boolean = { "true" | "false" }
number = { ASCII_DIGIT+ }
string = { "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
shell_string = { shell_prefix ~ string }
shell_prefix = { "sh" | "bash" | "zsh" | "pwsh" | "cmd" }

// --- Identifiers ---
identifier = { (ASCII_ALPHANUMERIC | "_" | "-" | ".")+ }

// --- Arguments ---
parameter = { identifier }
arguments = { parameter ~ ("," ~ parameter)* }